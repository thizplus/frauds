{
  "name": "playwright-recorder",
  "version": "1.0.0",
  "description": "Screen recording flows สำหรับ เช็กคนโกง.com",
  "scripts": {
    "record:all": "npx playwright test --project=mobile",
    "record:search": "npx playwright test flows/A01 --project=mobile",
    "record:detail": "npx playwright test flows/A03 --project=mobile",
    "record:face": "npx playwright test flows/A04 --project=mobile",
    "record:check": "npx playwright test flows/G05 --project=mobile",
    "record:flag": "npx playwright test flows/G06 --project=mobile",
    "record:clear": "npx playwright test flows/G07 --project=mobile",
    "record:report": "npx playwright test flows/C01 --project=mobile",
    "record:subscribe": "npx playwright test flows/E02 --project=mobile",
    "record:lender": "npx playwright test flows/G01 --project=mobile",
    "record:register": "npx playwright test flows/G03 --project=mobile",
    "trim": "bash trim.sh 5",
    "trim:3": "bash trim.sh 3"
  },
  "dependencies": {
    "@playwright/test": "^1.60.0",
    "playwright": "^1.60.0"
  }
}
