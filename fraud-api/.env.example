# App
APP_NAME=fraud-api
APP_PORT=3000
APP_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=fraud_checker
DB_SSL_MODE=disable

# Auth
JWT_SECRET=your-secret-key-min-32-chars
BOT_API_KEY=your-bot-api-key-here

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=both
LOG_FILE=logs/app.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=5
LOG_MAX_AGE=30
LOG_COMPRESS=true
