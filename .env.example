# =============================================================
# Environment Variables Template
# Copy to .env and fill in real values:  cp .env.example .env
# =============================================================

# ===== CORS =====
CORS_ORIGINS=https://your-domain.com,http://localhost:3001,http://localhost:5173

# ===== Database =====
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_NAME=fraud_checker

# ===== Auth =====
JWT_SECRET=CHANGE_ME_minimum_32_chars_random_hex
BOT_API_KEY=CHANGE_ME_random_hex
ADMIN_EMAIL=admin@fraudchecker.com
ADMIN_PASSWORD=CHANGE_ME_strong_password

# ===== Redis =====
REDIS_PASSWORD=CHANGE_ME_random_password

# ===== Storage (Cloudflare R2) =====
STORAGE_PROVIDER=s3
STORAGE_ENDPOINT=https://YOUR_ACCOUNT.r2.cloudflarestorage.com
STORAGE_BUCKET=fraud-checker
STORAGE_ACCESS_KEY=CHANGE_ME
STORAGE_SECRET_KEY=CHANGE_ME
STORAGE_REGION=auto
STORAGE_PUBLIC_URL=https://pub-XXXX.r2.dev

# ===== LINE OAuth (Login Channel) =====
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CALLBACK_URL=https://your-domain.com/auth/line/callback
LINE_LIFF_ID=

# ===== LINE Messaging API (Bot Channel) =====
LINE_MESSAGING_CHANNEL_ID=
LINE_MESSAGING_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_RICH_MENU_FREE=
LINE_RICH_MENU_MEMBER=

# ===== Face Service =====
FACE_CONFIDENCE_THRESHOLD=0.65
FACE_MIN_SIZE=80
